@page "/workspaces/{WorkspaceId:guid}/probes/{ProbeId:guid}"
@rendermode InteractiveServer
@attribute [Authorize]
@inject IDbContextFactory<ScryDbContext> DbFactory
@inject NavigationManager Nav

<PageTitle>@(probe?.Name ?? "Probe") — Scry</PageTitle>

@if (probe is null)
{
    <p class="text-muted">Probe not found.</p>
    return;
}

<div class="d-flex align-items-center mb-1">
    <a href="/workspaces/@WorkspaceId/probes" class="text-muted text-decoration-none small me-2">
        <i class="bi bi-arrow-left"></i> Probes
    </a>
</div>

<div class="d-flex align-items-center justify-content-between mb-4">
    <div class="d-flex align-items-center gap-3">
        <span class="dot @DotClass(latestOutcome)" style="width:14px;height:14px;"></span>
        <div>
            <h1 class="page-title">@probe.Name</h1>
            <p class="page-subtitle mb-0">@probe.Kind · every @probe.Interval
                · @(probe.Enabled ? "Active" : "Paused")</p>
        </div>
    </div>
    <div class="d-flex align-items-center gap-2">
        @if (latestOutcome.HasValue)
        {
            <span class="badge @BadgeClass(latestOutcome.Value) fs-6 px-3 py-2">@latestOutcome</span>
        }
        @if (!editing && !confirmDelete)
        {
            <button class="btn btn-sm btn-outline-secondary" @onclick="StartEdit">
                <i class="bi bi-pencil me-1"></i>Edit
            </button>
            <button class="btn btn-sm btn-outline-danger" @onclick="() => confirmDelete = true">
                <i class="bi bi-trash me-1"></i>Delete
            </button>
        }
    </div>
</div>

@if (confirmDelete)
{
    <div class="scry-card p-4 mb-4 border-danger">
        <p class="mb-3">Delete <strong>@probe.Name</strong>? This removes the probe and all its history. This cannot be undone.</p>
        <div class="d-flex gap-2">
            <button class="btn btn-danger" @onclick="DeleteAsync">Yes, delete</button>
            <button class="btn btn-secondary" @onclick="() => confirmDelete = false">Cancel</button>
        </div>
    </div>
}

@if (editing)
{
    <div class="scry-card mb-4">
        <div class="scry-card-header"><i class="bi bi-pencil me-2"></i>Edit probe</div>
        <div class="p-4">
            <div class="row g-3 mb-3">
                <div class="col-md-6">
                    <label class="form-label sidebar-label">Name</label>
                    <input type="text" class="form-control" @bind="editName" />
                </div>
                <div class="col-md-3">
                    <label class="form-label sidebar-label">Interval (HH:MM:SS)</label>
                    <input type="text" class="form-control font-mono" @bind="editInterval" placeholder="00:05:00" />
                </div>
                <div class="col-md-3 d-flex align-items-end">
                    <div class="form-check form-switch mb-2">
                        <input class="form-check-input" type="checkbox" id="enabledSwitch" @bind="editEnabled" />
                        <label class="form-check-label" for="enabledSwitch">Enabled</label>
                    </div>
                </div>
            </div>
            <div class="mb-3">
                <label class="form-label sidebar-label">Definition (YAML)</label>
                <textarea class="form-control font-mono" rows="14" @bind="editDefinition"></textarea>
            </div>
            @if (saveError is not null)
            {
                <div class="alert alert-danger py-2 small">@saveError</div>
            }
            <div class="d-flex gap-2">
                <button class="btn btn-primary" @onclick="SaveAsync">Save changes</button>
                <button class="btn btn-outline-secondary" @onclick="CancelEdit">Cancel</button>
            </div>
        </div>
    </div>
}

<div class="row g-3 mb-4">
    @if (results.Count > 0)
    {
        var latest = results[0];
        <div class="col-md-4">
            <div class="scry-card p-3">
                <div class="sidebar-label">Latest message</div>
                <p class="mb-0 small">@latest.Message</p>
            </div>
        </div>
        <div class="col-md-4">
            <div class="scry-card p-3">
                <div class="sidebar-label">Last run</div>
                <p class="mb-0 small">@latest.CompletedAt.ToString("yyyy-MM-dd HH:mm:ss") UTC</p>
            </div>
        </div>
        <div class="col-md-4">
            <div class="scry-card p-3">
                <div class="sidebar-label">Duration</div>
                <p class="mb-0 small">@latest.DurationMs ms</p>
            </div>
        </div>
    }
</div>

@if (!editing)
{
    <div class="scry-card mb-3">
        <div class="scry-card-header"><i class="bi bi-code me-2"></i>Definition (YAML)</div>
        <pre class="p-3 mb-0 font-mono" style="font-size:0.8rem;white-space:pre-wrap;word-break:break-all;">@probe.Definition</pre>
    </div>
}

@if (results.Count > 0 && results[0].Attributes.Count > 0)
{
    <div class="scry-card mb-3">
        <div class="scry-card-header"><i class="bi bi-tags me-2"></i>Attributes (latest run)</div>
        <div class="p-3">
            <div class="row g-2">
                @foreach (var (k, v) in results[0].Attributes)
                {
                    <div class="col-md-6">
                        <div class="d-flex justify-content-between small">
                            <span class="text-muted font-mono">@k</span>
                            <span class="font-mono">@v</span>
                        </div>
                    </div>
                }
            </div>
        </div>
    </div>
}

<div class="scry-card">
    <div class="scry-card-header"><i class="bi bi-clock-history me-2"></i>Result history (last 100)</div>
    @if (results.Count == 0)
    {
        <div class="p-4 text-center text-muted">No results yet — probe has not run.</div>
    }
    else
    {
        <table class="table scry-table mb-0">
            <thead>
                <tr>
                    <th style="width:14px"></th>
                    <th>Outcome</th>
                    <th>Message</th>
                    <th>Completed</th>
                    <th>Duration</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var r in results)
                {
                    <tr>
                        <td><span class="dot @DotClass(r.Outcome)"></span></td>
                        <td><span class="badge @BadgeClass(r.Outcome)">@r.Outcome</span></td>
                        <td class="text-muted" style="max-width:320px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap">
                            @r.Message
                        </td>
                        <td class="text-muted">@r.CompletedAt.ToString("yyyy-MM-dd HH:mm:ss") UTC</td>
                        <td class="text-muted">@r.DurationMs ms</td>
                    </tr>
                }
            </tbody>
        </table>
    }
</div>

@code {
    [Parameter] public Guid WorkspaceId { get; set; }
    [Parameter] public Guid ProbeId { get; set; }

    private Probe? probe;
    private List<ProbeResult> results = [];
    private ProbeOutcome? latestOutcome;

    private bool editing;
    private bool confirmDelete;
    private string editName = "";
    private string editInterval = "";
    private bool editEnabled;
    private string editDefinition = "";
    private string? saveError;

    protected override async Task OnInitializedAsync()
    {
        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        await using var ctx = await DbFactory.CreateDbContextAsync();
        ctx.CurrentWorkspaceId = WorkspaceId;

        probe = await ctx.Probes.FirstOrDefaultAsync(p => p.Id == ProbeId);
        if (probe is null) return;

        results = await ctx.ProbeResults
            .Where(r => r.ProbeId == ProbeId)
            .OrderByDescending(r => r.CompletedAt)
            .Take(100)
            .ToListAsync();

        latestOutcome = results.Count > 0 ? results[0].Outcome : null;
    }

    private void StartEdit()
    {
        editName = probe!.Name;
        editInterval = probe.Interval.ToString(@"hh\:mm\:ss");
        editEnabled = probe.Enabled;
        editDefinition = probe.Definition;
        saveError = null;
        editing = true;
    }

    private void CancelEdit()
    {
        editing = false;
        saveError = null;
    }

    private async Task SaveAsync()
    {
        if (!TimeSpan.TryParse(editInterval, out var interval) || interval <= TimeSpan.Zero)
        {
            saveError = "Interval must be a valid time span (e.g. 00:05:00).";
            return;
        }
        if (string.IsNullOrWhiteSpace(editName))
        {
            saveError = "Name is required.";
            return;
        }

        await using var ctx = await DbFactory.CreateDbContextAsync();
        ctx.CurrentWorkspaceId = WorkspaceId;
        var p = await ctx.Probes.FirstOrDefaultAsync(x => x.Id == ProbeId);
        if (p is null) return;

        p.Name = editName.Trim();
        p.Definition = editDefinition;
        p.Interval = interval;
        p.Enabled = editEnabled;
        await ctx.SaveChangesAsync();

        editing = false;
        saveError = null;
        await LoadAsync();
    }

    private async Task DeleteAsync()
    {
        await using var ctx = await DbFactory.CreateDbContextAsync();
        ctx.CurrentWorkspaceId = WorkspaceId;
        var p = await ctx.Probes.FirstOrDefaultAsync(x => x.Id == ProbeId);
        if (p is not null)
        {
            ctx.Probes.Remove(p);
            await ctx.SaveChangesAsync();
        }
        Nav.NavigateTo($"/workspaces/{WorkspaceId}/probes");
    }

    private static string DotClass(ProbeOutcome? o) => o switch
    {
        ProbeOutcome.Ok    => "dot-ok",
        ProbeOutcome.Warn  => "dot-warn",
        ProbeOutcome.Crit  => "dot-crit",
        ProbeOutcome.Error => "dot-error",
        _                  => "dot-unknown",
    };

    private static string BadgeClass(ProbeOutcome o) => o switch
    {
        ProbeOutcome.Ok    => "badge-ok",
        ProbeOutcome.Warn  => "badge-warn",
        ProbeOutcome.Crit  => "badge-crit",
        ProbeOutcome.Error => "badge-error",
        _                  => "badge-unknown",
    };
}
