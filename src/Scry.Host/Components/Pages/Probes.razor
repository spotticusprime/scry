@page "/workspaces/{WorkspaceId:guid}/probes"
@attribute [Authorize]
@inject IDbContextFactory<ScryDbContext> DbFactory
@inject IJobQueue JobQueue
@inject NavigationManager Nav
@using Scry.Probes
@using Scry.Core

<PageTitle>Probes — Scry</PageTitle>

<div class="d-flex align-items-start justify-content-between mb-4">
    <div>
        <h1 class="page-title">Probes</h1>
        <p class="page-subtitle">@probes.Count probe@(probes.Count != 1 ? "s" : "") in this workspace</p>
    </div>
    @if (!creating)
    {
        <button class="btn btn-primary btn-sm" @onclick="() => creating = true">
            <i class="bi bi-plus-lg"></i>New probe
        </button>
    }
</div>

@if (creating)
{
    <div class="scry-card mb-4">
        <div class="scry-card-header"><i class="bi bi-plus-circle"></i>New probe</div>
        <div class="p-4">
            <div class="row g-3 mb-3">
                <div class="col-md-5">
                    <label class="form-label">Name</label>
                    <input type="text" class="form-control" @bind="newName"
                           placeholder="e.g. API — HTTPS check" autofocus />
                </div>
                <div class="col-md-3">
                    <label class="form-label">Kind</label>
                    <select class="form-select" @bind="newKind">
                        <option value="http">http</option>
                        <option value="tls">tls</option>
                        <option value="dns">dns</option>
                        <option value="azure_metric">azure_metric</option>
                        <option value="sql_kpi">sql_kpi</option>
                    </select>
                </div>
                <div class="col-md-2">
                    <label class="form-label">Interval (HH:MM:SS)</label>
                    <input type="text" class="form-control font-mono" @bind="newInterval" placeholder="00:05:00" />
                </div>
            </div>
            <div class="mb-3">
                <label class="form-label">Definition (YAML)</label>
                <textarea class="form-control" rows="9" @bind="newDefinition"
                          placeholder="@Placeholder(newKind)"></textarea>
            </div>
            @if (createError is not null)
            {
                <div class="alert alert-danger py-2 small"><i class="bi bi-exclamation-triangle me-1"></i>@createError</div>
            }
            <div class="d-flex gap-2">
                <button class="btn btn-primary" @onclick="CreateAsync"><i class="bi bi-check-lg"></i>Create</button>
                <button class="btn btn-outline-secondary" @onclick="CancelCreate">Cancel</button>
            </div>
        </div>
    </div>
}

<div class="scry-card">
    <div class="scry-card-header"><i class="bi bi-broadcast"></i>All probes</div>

    @if (probes.Count == 0)
    {
        <div class="p-5 text-center" style="color:var(--text-3);">
            <i class="bi bi-broadcast" style="font-size:2rem;display:block;margin-bottom:10px;opacity:0.4;"></i>
            <p>No probes yet. Use the <strong style="color:var(--text-2);">New probe</strong> button above.</p>
        </div>
    }
    else
    {
        @foreach (var row in probes)
        {
            <div class="probe-row probe-row-@OutcomeSlug(row.Outcome)">
                <span class="dot @DotClass(row.Outcome)" style="width:9px;height:9px;flex-shrink:0;"></span>
                <div style="flex:1;min-width:0;">
                    <div class="d-flex align-items-center gap-2 mb-1">
                        <a href="/workspaces/@WorkspaceId/probes/@row.Probe.Id"
                           style="font-weight:600;font-size:13px;color:var(--text-1);text-decoration:none;">
                            @row.Probe.Name
                        </a>
                        <span class="font-mono" style="font-size:10.5px;color:var(--text-3);">@row.Probe.Kind</span>
                        <span style="font-size:11px;color:var(--text-3);">every @row.Probe.Interval</span>
                    </div>
                    <div style="font-size:12px;color:var(--text-3);overflow:hidden;text-overflow:ellipsis;white-space:nowrap;max-width:480px;">
                        @(row.Message ?? "No results yet")
                    </div>
                </div>
                <div class="d-flex align-items-center gap-3 flex-shrink-0">
                    @if (row.Outcome.HasValue)
                    {
                        <span class="badge @BadgeClass(row.Outcome.Value)" style="min-width:52px;justify-content:center;">@row.Outcome</span>
                    }
                    else
                    {
                        <span class="badge badge-unknown" style="min-width:52px;justify-content:center;">—</span>
                    }
                    <span style="font-size:12px;color:var(--text-3);min-width:52px;text-align:right;">
                        @Ago(row.CompletedAt)
                    </span>
                    <button class="btn btn-sm @(row.Probe.Enabled ? "btn-outline-secondary" : "btn-outline-success")"
                            style="min-width:70px;"
                            @onclick="() => ToggleEnabledAsync(row.Probe.Id, !row.Probe.Enabled)">
                        @(row.Probe.Enabled ? "Pause" : "Resume")
                    </button>
                </div>
            </div>
        }
    }
</div>

@code {
    [Parameter] public Guid WorkspaceId { get; set; }

    private List<ProbeRow> probes = [];
    private bool creating;
    private string newName = "";
    private string newKind = "http";
    private string newInterval = "00:05:00";
    private string newDefinition = "";
    private string? createError;

    protected override async Task OnInitializedAsync() => await LoadAsync();

    private async Task LoadAsync()
    {
        await using var ctx = await DbFactory.CreateDbContextAsync();
        ctx.CurrentWorkspaceId = WorkspaceId;

        var allProbes = await ctx.Probes.OrderBy(p => p.Name).ToListAsync();
        var latestResults = await ctx.ProbeResults
            .GroupBy(r => r.ProbeId)
            .Select(g => g.OrderByDescending(r => r.CompletedAt).First())
            .ToListAsync();

        var resultMap = latestResults.ToDictionary(r => r.ProbeId);
        probes = allProbes.Select(p =>
        {
            resultMap.TryGetValue(p.Id, out var result);
            return new ProbeRow(p, result?.Outcome, result?.Message, result?.CompletedAt);
        }).ToList();
    }

    private void CancelCreate()
    {
        creating = false;
        createError = null;
        newName = ""; newKind = "http"; newInterval = "00:05:00"; newDefinition = "";
    }

    private async Task CreateAsync()
    {
        if (string.IsNullOrWhiteSpace(newName)) { createError = "Name is required."; return; }
        if (!TimeSpan.TryParse(newInterval, out var interval) || interval <= TimeSpan.Zero)
        {
            createError = "Interval must be a valid time span (e.g. 00:05:00)."; return;
        }
        if (string.IsNullOrWhiteSpace(newDefinition)) { createError = "Definition is required."; return; }

        await using var ctx = await DbFactory.CreateDbContextAsync();
        var probe = new Probe
        {
            WorkspaceId = WorkspaceId,
            Name = newName.Trim(),
            Kind = newKind,
            Definition = newDefinition,
            Interval = interval,
        };
        ctx.Probes.Add(probe);
        await ctx.SaveChangesAsync();
        await JobQueue.EnqueueAsync(ScryProbesExtensions.CreateInitialProbeJob(probe));

        CancelCreate();
        await LoadAsync();
    }

    private async Task ToggleEnabledAsync(Guid probeId, bool enabled)
    {
        await using var ctx = await DbFactory.CreateDbContextAsync();
        ctx.CurrentWorkspaceId = WorkspaceId;
        var p = await ctx.Probes.FirstOrDefaultAsync(x => x.Id == probeId);
        if (p is null) return;
        var wasDisabled = !p.Enabled;
        p.Enabled = enabled;
        await ctx.SaveChangesAsync();
        if (enabled && wasDisabled)
            await JobQueue.EnqueueAsync(ScryProbesExtensions.CreateInitialProbeJob(p));
        await LoadAsync();
    }

    private static string Placeholder(string kind) => kind switch
    {
        "http"         => "url: https://example.com\nexpected_status: 200\ntimeout: 00:00:15",
        "tls"          => "host: example.com\nwarn_days: 30\ncrit_days: 7",
        "dns"          => "host: example.com\ntimeout: 00:00:10",
        "azure_metric" => "subscription_id: \"<sub-id>\"\nresource_group: \"<rg>\"\nresource_name: \"<name>\"\nresource_type: Microsoft.Web/sites\nmetrics:\n  - name: CpuPercentage\n    warn_threshold: 70\n    crit_threshold: 90",
        "sql_kpi"      => "connection_string_name: MyDb\nquery: \"SELECT TOP 1 CreatedAt FROM Orders ORDER BY CreatedAt DESC\"\ndescription: Last order\nwarn_age_minutes: 30\ncrit_age_minutes: 60",
        _ => "",
    };

    private static string OutcomeSlug(ProbeOutcome? o) => o switch
    {
        ProbeOutcome.Ok    => "ok",
        ProbeOutcome.Warn  => "warn",
        ProbeOutcome.Crit  => "crit",
        ProbeOutcome.Error => "error",
        _                  => "unknown",
    };

    private static string DotClass(ProbeOutcome? o) => o switch
    {
        ProbeOutcome.Ok    => "dot-ok",
        ProbeOutcome.Warn  => "dot-warn",
        ProbeOutcome.Crit  => "dot-crit",
        ProbeOutcome.Error => "dot-error",
        _                  => "dot-unknown",
    };

    private static string BadgeClass(ProbeOutcome o) => o switch
    {
        ProbeOutcome.Ok    => "badge-ok",
        ProbeOutcome.Warn  => "badge-warn",
        ProbeOutcome.Crit  => "badge-crit",
        ProbeOutcome.Error => "badge-error",
        _                  => "badge-unknown",
    };

    private static string Ago(DateTimeOffset? t)
    {
        if (t is null) return "—";
        var diff = DateTimeOffset.UtcNow - t.Value;
        return diff.TotalMinutes < 1  ? $"{(int)diff.TotalSeconds}s ago"
             : diff.TotalHours < 1    ? $"{(int)diff.TotalMinutes}m ago"
             : diff.TotalDays < 1     ? $"{(int)diff.TotalHours}h ago"
             : t.Value.ToString("MMM d");
    }

    private sealed record ProbeRow(Probe Probe, ProbeOutcome? Outcome, string? Message, DateTimeOffset? CompletedAt);
}
