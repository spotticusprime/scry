@page "/workspaces/{WorkspaceId:guid}/alerts"
@attribute [Authorize]
@inject IDbContextFactory<ScryDbContext> DbFactory

<PageTitle>Alerts — Scry</PageTitle>

<div class="d-flex align-items-start justify-content-between mb-4">
    <div>
        <h1 class="page-title">Alerts</h1>
        <p class="page-subtitle">@rules.Count rule@(rules.Count != 1 ? "s" : "") · @firingCount firing</p>
    </div>
    @if (firingCount > 0)
    {
        <span class="alert-firing" style="animation:none;">
            <i class="bi bi-bell-fill"></i>@firingCount firing
        </span>
    }
</div>

@if (firingEvents.Count > 0)
{
    <div class="mb-4">
        <div class="scry-card" style="border-color:rgba(248,113,113,0.25);">
            <div class="scry-card-header" style="color:var(--crit);">
                <i class="bi bi-bell-fill"></i>Firing alerts
            </div>
            @foreach (var evt in firingEvents)
            {
                <div style="display:flex;align-items:flex-start;gap:12px;padding:12px 16px;border-bottom:1px solid var(--border-dim);">
                    <span class="dot dot-crit" style="width:8px;height:8px;flex-shrink:0;margin-top:4px;"></span>
                    <div style="flex:1;min-width:0;">
                        <div class="d-flex align-items-center gap-2 mb-1">
                            <span style="font-weight:600;font-size:13px;">
                                @(ruleMap.GetValueOrDefault(evt.AlertRuleId)?.Name ?? "Unknown rule")
                            </span>
                            <span class="badge @SeverityBadge(evt.Severity)">@evt.Severity</span>
                        </div>
                        <div style="font-size:12px;color:var(--text-3);">@(evt.Summary ?? "—")</div>
                    </div>
                    <div style="text-align:right;flex-shrink:0;min-width:100px;">
                        <div style="font-size:12px;color:var(--text-3);">@Ago(evt.OpenedAt)</div>
                        @if (evt.LastNotifiedAt.HasValue)
                        {
                            <div style="font-size:11px;color:var(--text-3);">notified @Ago(evt.LastNotifiedAt.Value)</div>
                        }
                    </div>
                </div>
            }
        </div>
    </div>
}

<div class="scry-card">
    <div class="scry-card-header"><i class="bi bi-sliders"></i>Rules</div>
    @if (rules.Count == 0)
    {
        <div class="p-5 text-center" style="color:var(--text-3);">
            <i class="bi bi-sliders" style="font-size:2rem;display:block;margin-bottom:10px;opacity:0.3;"></i>
            <p style="margin-bottom:8px;">No alert rules yet.</p>
            <code>POST /api/workspaces/@WorkspaceId/alerts</code>
        </div>
    }
    else
    {
        <table class="table scry-table mb-0">
            <thead>
                <tr>
                    <th>Name</th>
                    <th>Expression</th>
                    <th>Severity</th>
                    <th>Notifier</th>
                    <th>Probe filter</th>
                    <th>Status</th>
                    <th>Firing</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var rule in rules)
                {
                    var activeCount = firingEvents.Count(e => e.AlertRuleId == rule.Id);
                    <tr>
                        <td style="font-weight:600;">@rule.Name</td>
                        <td><code>@rule.Expression</code></td>
                        <td><span class="badge @SeverityBadge(rule.Severity)">@rule.Severity</span></td>
                        <td style="font-size:12px;color:var(--text-3);">@NotifierKind(rule.NotifierConfig)</td>
                        <td style="font-size:12px;color:var(--text-3);">
                            @(rule.ProbeIdFilter.HasValue ? rule.ProbeIdFilter.Value.ToString()[..8] + "…" : "All probes")
                        </td>
                        <td>
                            @if (rule.Enabled)
                            {
                                <span class="badge badge-ok">Active</span>
                            }
                            else
                            {
                                <span class="badge badge-unknown">Disabled</span>
                            }
                        </td>
                        <td>
                            @if (activeCount > 0)
                            {
                                <span class="badge badge-crit">@activeCount firing</span>
                            }
                            else
                            {
                                <span style="color:var(--text-3);font-size:12px;">—</span>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    }
</div>

@code {
    [Parameter] public Guid WorkspaceId { get; set; }

    private List<AlertRule> rules = [];
    private Dictionary<Guid, AlertRule> ruleMap = [];
    private List<AlertEvent> firingEvents = [];
    private int firingCount;

    protected override async Task OnInitializedAsync()
    {
        await using var ctx = await DbFactory.CreateDbContextAsync();
        ctx.CurrentWorkspaceId = WorkspaceId;
        rules = await ctx.AlertRules.OrderBy(r => r.Name).ToListAsync();
        ruleMap = rules.ToDictionary(r => r.Id);
        firingEvents = await ctx.AlertEvents.Where(e => e.State == AlertState.Firing)
            .OrderByDescending(e => e.OpenedAt).ToListAsync();
        firingCount = firingEvents.Count;
    }

    private static string SeverityBadge(AlertSeverity s) => s switch
    {
        AlertSeverity.Critical or AlertSeverity.Error => "badge-crit",
        AlertSeverity.Warning                         => "badge-warn",
        _                                             => "badge-unknown",
    };

    private static string NotifierKind(string? config)
    {
        if (string.IsNullOrWhiteSpace(config)) return "—";
        try
        {
            using var doc = System.Text.Json.JsonDocument.Parse(config);
            return doc.RootElement.TryGetProperty("kind", out var k) ? k.GetString() ?? "webhook" : "webhook";
        }
        catch { return "webhook"; }
    }

    private static string Ago(DateTimeOffset t)
    {
        var diff = DateTimeOffset.UtcNow - t;
        return diff.TotalMinutes < 1  ? $"{(int)diff.TotalSeconds}s ago"
             : diff.TotalHours < 1    ? $"{(int)diff.TotalMinutes}m ago"
             : diff.TotalDays < 1     ? $"{(int)diff.TotalHours}h ago"
             : t.ToString("MMM d");
    }
}
