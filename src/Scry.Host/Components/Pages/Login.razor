@page "/login"
@layout Scry.Host.Components.Layout.EmptyLayout
@attribute [AllowAnonymous]

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Scry — Sign in</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <link rel="stylesheet" href="/app.css" />
</head>
<body class="bg-dark text-white">

<div class="login-box">
    <div class="text-center mb-4">
        <i class="bi bi-eye-fill text-primary" style="font-size: 2.5rem;"></i>
        <h2 class="mt-2 fw-bold">Scry</h2>
        <p class="text-muted small">Infrastructure monitoring</p>
    </div>

    <div class="scry-card p-4">
        @if (ErrorMessage is not null)
        {
            <div class="alert alert-danger py-2 mb-3 small">@ErrorMessage</div>
        }

        <form method="post" action="/auth/login">
            <AntiforgeryToken />
            <input type="hidden" name="returnUrl" value="@ReturnUrl" />

            <div class="mb-3">
                <label class="form-label text-muted small">Username</label>
                <input type="text" name="username" class="form-control"
                       style="background:#2d3039;border-color:#3d4252;color:#e0e0e0"
                       autofocus autocomplete="username" required />
            </div>

            <div class="mb-4">
                <label class="form-label text-muted small">Password</label>
                <input type="password" name="password" class="form-control"
                       style="background:#2d3039;border-color:#3d4252;color:#e0e0e0"
                       autocomplete="current-password" required />
            </div>

            <button type="submit" class="btn btn-primary w-100">Sign in</button>
        </form>
    </div>
</div>

</body>
</html>

@code {
    [SupplyParameterFromQuery] public string? ReturnUrl { get; set; }
    [SupplyParameterFromQuery] public string? Error { get; set; }

    private string? ErrorMessage => Error == "1" ? "Invalid username or password." : null;
}
