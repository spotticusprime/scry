@page "/login"
@layout Scry.Host.Components.Layout.EmptyLayout
@attribute [AllowAnonymous]

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Scry — Sign in</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin="anonymous" />
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <link rel="stylesheet" href="/app.css" />
</head>
<body>

<div class="login-page">
    <div class="login-glow"></div>

    <div class="login-box">
        <div class="login-logo">
            <div class="login-logo-mark">
                <i class="bi bi-eye-fill"></i>
            </div>
            <div style="font-size:20px;font-weight:700;color:#f1f5f9;letter-spacing:-0.4px;">Scry</div>
            <div style="font-size:12px;color:#4b5563;margin-top:3px;">Infrastructure monitoring</div>
        </div>

        <div class="scry-card p-4">
            @if (ErrorMessage is not null)
            {
                <div class="alert alert-danger py-2 mb-3 small">
                    <i class="bi bi-exclamation-triangle me-1"></i>@ErrorMessage
                </div>
            }

            <form method="post" action="/auth/login">
                <AntiforgeryToken />
                <input type="hidden" name="returnUrl" value="@ReturnUrl" />

                <div class="mb-3">
                    <label class="form-label">Username</label>
                    <input type="text" name="username" class="form-control"
                           autofocus autocomplete="username" required
                           placeholder="admin" />
                </div>

                <div class="mb-4">
                    <label class="form-label">Password</label>
                    <input type="password" name="password" class="form-control"
                           autocomplete="current-password" required
                           placeholder="••••••••" />
                </div>

                <button type="submit" class="btn btn-primary w-100" style="padding:9px;">
                    <i class="bi bi-arrow-right-circle me-1"></i>Sign in
                </button>
            </form>
        </div>
    </div>
</div>

</body>
</html>

@code {
    [SupplyParameterFromQuery] public string? ReturnUrl { get; set; }
    [SupplyParameterFromQuery] public string? Error { get; set; }

    private string? ErrorMessage => Error == "1" ? "Invalid username or password." : null;
}
