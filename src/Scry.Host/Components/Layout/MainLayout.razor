@inherits LayoutComponentBase
@inject NavigationManager Nav
@inject IDbContextFactory<ScryDbContext> DbFactory

<div class="d-flex vh-100">
    <!-- Sidebar -->
    <nav class="sidebar d-flex flex-column flex-shrink-0 p-3">
        <a href="/" class="d-flex align-items-center mb-3 mb-md-0 me-md-auto text-decoration-none">
            <i class="bi bi-eye-fill me-2 fs-4 text-primary"></i>
            <span class="fs-5 fw-semibold text-white">Scry</span>
        </a>
        <hr class="border-secondary" />

        @if (workspaces.Count > 0)
        {
            <div class="mb-2">
                <label class="sidebar-label">Workspace</label>
                <select class="form-select form-select-sm workspace-select" @onchange="OnWorkspaceChanged" value="@CurrentWorkspaceId">
                    @foreach (var ws in workspaces)
                    {
                        <option value="@ws.Id">@ws.Name</option>
                    }
                </select>
            </div>
        }

        <ul class="nav nav-pills flex-column mb-auto">
            <li class="nav-item">
                <a href="@DashboardHref" class="nav-link @ActiveClass("/")">
                    <i class="bi bi-grid-fill me-2"></i> Dashboard
                </a>
            </li>
            <li class="nav-item">
                <a href="@ProbesHref" class="nav-link @ActiveClass("/probes")">
                    <i class="bi bi-broadcast me-2"></i> Probes
                </a>
            </li>
            <li class="nav-item">
                <a href="@CertsHref" class="nav-link @ActiveClass("/certs")">
                    <i class="bi bi-shield-lock me-2"></i> Certificates
                </a>
            </li>
            <li class="nav-item">
                <a href="@TopologyHref" class="nav-link @ActiveClass("/topology")">
                    <i class="bi bi-diagram-3 me-2"></i> Topology
                </a>
            </li>
            <li class="nav-item">
                <a href="@AlertsHref" class="nav-link @ActiveClass("/alerts")">
                    <i class="bi bi-bell-fill me-2"></i> Alerts
                </a>
            </li>
        </ul>

        <hr class="border-secondary" />
        <ul class="nav nav-pills flex-column">
            <li class="nav-item">
                <a href="/inventory" class="nav-link @ActiveClass("/inventory")">
                    <i class="bi bi-list-check me-2"></i> Inventory
                </a>
            </li>
            <li class="nav-item">
                <a href="/workspaces" class="nav-link @ActiveClass("/workspaces")">
                    <i class="bi bi-diagram-3 me-2"></i> Workspaces
                </a>
            </li>
            <li class="nav-item">
                <a href="/auth/logout" class="nav-link text-secondary">
                    <i class="bi bi-box-arrow-right me-2"></i> Sign out
                </a>
            </li>
        </ul>
    </nav>

    <!-- Main content -->
    <main class="flex-grow-1 overflow-auto bg-dark-subtle">
        <div class="p-4">
            @Body
        </div>
    </main>
</div>

@code {
    private List<Workspace> workspaces = [];
    private Guid? CurrentWorkspaceId;

    protected override async Task OnInitializedAsync()
    {
        await using var ctx = await DbFactory.CreateDbContextAsync();
        workspaces = await ctx.Workspaces.OrderBy(w => w.Name).ToListAsync();

        var uri = new Uri(Nav.Uri);
        var segments = uri.AbsolutePath.Split('/', StringSplitOptions.RemoveEmptyEntries);
        if (segments.Length >= 2 && segments[0] == "workspaces"
            && Guid.TryParse(segments[1], out var id))
        {
            CurrentWorkspaceId = id;
        }
        else if (workspaces.Count > 0)
        {
            CurrentWorkspaceId = workspaces[0].Id;
        }
    }

    private void OnWorkspaceChanged(ChangeEventArgs e)
    {
        if (Guid.TryParse(e.Value?.ToString(), out var id))
        {
            Nav.NavigateTo($"/workspaces/{id}", forceLoad: false);
        }
    }

    private string DashboardHref => CurrentWorkspaceId.HasValue
        ? $"/workspaces/{CurrentWorkspaceId}" : "/workspaces";

    private string ProbesHref => CurrentWorkspaceId.HasValue
        ? $"/workspaces/{CurrentWorkspaceId}/probes" : "/workspaces";

    private string CertsHref => CurrentWorkspaceId.HasValue
        ? $"/workspaces/{CurrentWorkspaceId}/certs" : "/workspaces";

    private string TopologyHref => CurrentWorkspaceId.HasValue
        ? $"/workspaces/{CurrentWorkspaceId}/topology" : "/workspaces";

    private string AlertsHref => CurrentWorkspaceId.HasValue
        ? $"/workspaces/{CurrentWorkspaceId}/alerts" : "/workspaces";

    private string ActiveClass(string segment)
    {
        var path = new Uri(Nav.Uri).AbsolutePath;
        return segment switch
        {
            "/" => path == "/" || (path.StartsWith("/workspaces/") && !path.Contains("/probes") && !path.Contains("/alerts") && !path.Contains("/certs") && !path.Contains("/topology"))
                ? "active" : "",
            "/probes"    => path.Contains("/probes") ? "active" : "",
            "/certs"     => path.Contains("/certs") ? "active" : "",
            "/topology"  => path.Contains("/topology") ? "active" : "",
            "/alerts"    => path.Contains("/alerts") ? "active" : "",
            "/inventory" => path == "/inventory" ? "active" : "",
            "/workspaces" => path == "/workspaces" ? "active" : "",
            _ => "",
        };
    }
}
