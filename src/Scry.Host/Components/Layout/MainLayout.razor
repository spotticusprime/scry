@inherits LayoutComponentBase
@inject NavigationManager Nav
@inject IDbContextFactory<ScryDbContext> DbFactory

<div class="scry-shell">
    <nav class="scry-sidebar">
        <a href="/" class="scry-brand">
            <div class="scry-brand-icon"><i class="bi bi-eye-fill"></i></div>
            <span class="scry-brand-name">Scry</span>
        </a>

        @if (workspaces.Count > 0)
        {
            <div class="scry-ws-picker">
                <span class="scry-ws-label">Workspace</span>
                <select class="scry-ws-select" @onchange="OnWorkspaceChanged" value="@CurrentWorkspaceId">
                    @foreach (var ws in workspaces)
                    {
                        <option value="@ws.Id">@ws.Name</option>
                    }
                </select>
            </div>
        }

        <div class="scry-nav">
            <a href="@DashboardHref" class="scry-nav-item @ActiveClass("/")">
                <i class="bi bi-grid-1x2-fill"></i><span>Dashboard</span>
            </a>
            <a href="@ProbesHref" class="scry-nav-item @ActiveClass("/probes")">
                <i class="bi bi-broadcast"></i><span>Probes</span>
            </a>
            <a href="@CertsHref" class="scry-nav-item @ActiveClass("/certs")">
                <i class="bi bi-shield-lock-fill"></i><span>Certificates</span>
            </a>
            <a href="@TopologyHref" class="scry-nav-item @ActiveClass("/topology")">
                <i class="bi bi-diagram-3-fill"></i><span>Topology</span>
            </a>
            <a href="@AlertsHref" class="scry-nav-item @ActiveClass("/alerts")">
                <i class="bi bi-bell-fill"></i><span>Alerts</span>
            </a>
        </div>

        <div class="scry-sidebar-footer">
            <div class="scry-nav-sep"></div>
            <a href="/inventory" class="scry-nav-item @ActiveClass("/inventory")">
                <i class="bi bi-list-check"></i><span>Inventory</span>
            </a>
            <a href="/workspaces" class="scry-nav-item @ActiveClass("/workspaces")">
                <i class="bi bi-collection-fill"></i><span>Workspaces</span>
            </a>
            <a href="/auth/logout" class="scry-nav-item">
                <i class="bi bi-box-arrow-right"></i><span>Sign out</span>
            </a>
            <!-- Phase 1: single-node only — sticky sessions required for multi-node -->
            <div class="scry-node-badge" title="Blazor Interactive Server requires sticky sessions. Scale-out needs a Redis SignalR backplane.">
                <i class="bi bi-node-plus"></i>
                <span>Single-node mode</span>
            </div>
        </div>
    </nav>

    <main class="scry-main">
        <div class="scry-page">
            @Body
        </div>
    </main>
</div>

@code {
    private List<Workspace> workspaces = [];
    private Guid? CurrentWorkspaceId;

    protected override async Task OnInitializedAsync()
    {
        await using var ctx = await DbFactory.CreateDbContextAsync();
        workspaces = await ctx.Workspaces.OrderBy(w => w.Name).ToListAsync();

        var uri = new Uri(Nav.Uri);
        var segments = uri.AbsolutePath.Split('/', StringSplitOptions.RemoveEmptyEntries);
        if (segments.Length >= 2 && segments[0] == "workspaces" && Guid.TryParse(segments[1], out var id))
        {
            CurrentWorkspaceId = id;
        }
        else if (workspaces.Count > 0)
        {
            CurrentWorkspaceId = workspaces[0].Id;
        }
    }

    private void OnWorkspaceChanged(ChangeEventArgs e)
    {
        if (Guid.TryParse(e.Value?.ToString(), out var id))
            Nav.NavigateTo($"/workspaces/{id}", forceLoad: false);
    }

    private string DashboardHref => CurrentWorkspaceId.HasValue ? $"/workspaces/{CurrentWorkspaceId}" : "/workspaces";
    private string ProbesHref    => CurrentWorkspaceId.HasValue ? $"/workspaces/{CurrentWorkspaceId}/probes"    : "/workspaces";
    private string CertsHref     => CurrentWorkspaceId.HasValue ? $"/workspaces/{CurrentWorkspaceId}/certs"     : "/workspaces";
    private string TopologyHref  => CurrentWorkspaceId.HasValue ? $"/workspaces/{CurrentWorkspaceId}/topology"  : "/workspaces";
    private string AlertsHref    => CurrentWorkspaceId.HasValue ? $"/workspaces/{CurrentWorkspaceId}/alerts"    : "/workspaces";

    private string ActiveClass(string segment)
    {
        var path = new Uri(Nav.Uri).AbsolutePath;
        return segment switch
        {
            "/" => path == "/" || (path.StartsWith("/workspaces/") && !path.Contains("/probes") && !path.Contains("/alerts") && !path.Contains("/certs") && !path.Contains("/topology"))
                ? "active" : "",
            "/probes"     => path.Contains("/probes")     ? "active" : "",
            "/certs"      => path.Contains("/certs")      ? "active" : "",
            "/topology"   => path.Contains("/topology")   ? "active" : "",
            "/alerts"     => path.Contains("/alerts")     ? "active" : "",
            "/inventory"  => path == "/inventory"         ? "active" : "",
            "/workspaces" => path == "/workspaces"        ? "active" : "",
            _ => "",
        };
    }
}
